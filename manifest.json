{
  "manifest_version": 3,
  "name": "AI Conversation Exporter",
  "short_name": "AI Exporter",
  "version": "2.0.0",
  "description": "Export ChatGPT, Claude & Gemini conversations as TXT, Markdown, JSON or HTML. No data collection. No external requests.",

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Conversation Exporter"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "MacCtrl+Shift+S"
      },
      "description": "Open AI Conversation Exporter"
    }
  },

  "permissions": ["activeTab", "downloads"],

  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js":  ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "ai-conversation-exporter@extension",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [],
        "optional": []
      }
    }
  }
}
